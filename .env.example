# Copy this file to `.env` and fill from Supabase → Project Settings → API.
# EXPO_PUBLIC_ vars are read automatically by Expo and exposed to the client.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# New Supabase naming ("publishable key"). The old EXPO_PUBLIC_SUPABASE_ANON_KEY also works.
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR-PUBLISHABLE-KEY
